# ================================================================
# .gitignore — Digital Kaam Naka
# ================================================================

# ── Dependencies ────────────────────────────────────────────────
node_modules/
.npm
.yarn

# ── Environment Variables — NEVER commit ────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
server/.env
client/.env
client/.env.production
*.env

# ── Build Outputs ───────────────────────────────────────────────
client/build/
server/dist/
build/
dist/

# ── Logs ────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server/logs/

# ── OS Files ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Uploads (use Cloudinary in production) ──────────────────────
server/uploads/
client/public/uploads/

# ── Database ────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Test Coverage ───────────────────────────────────────────────
coverage/
.nyc_output/

# ── Certificates & Keys — NEVER commit ─────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
serviceAccountKey.json
firebase-adminsdk*.json
google-services.json
GoogleService-Info.plist

# ── Sequelize ───────────────────────────────────────────────────
server/migrations/*.js.bak

# ── Seeders (optional — don't commit seed data) ─────────────────
# server/seeders/